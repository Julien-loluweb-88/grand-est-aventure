// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String                     @id
  email                     String                     @unique
  name                      String?
  address                   String?
  postalCode                String?
  city                      String?
  country                   String?
  phone                     String?
  emailVerified             Boolean                    @default(false)
  image                     String?
  role                      String?                    @default("user")
  banned                    Boolean?                   @default(false)
  banReason                 String?
  banExpires                DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  sessions                  Session[]
  accounts                  Account[]
  userAdventures            UserAdventures[]
  adventures                Adventure[]                @relation("CreatedAdventures")
  /// Avis laissés sur les aventures.
  adventureReviews          AdventureReview[]
  adminAdventureAccesses    AdminAdventureAccess[]
  adminAuditLogsAsActor     AdminAuditLog[]            @relation("AdminAuditActor")
  adminAuditLogsAsTarget    AdminAuditLog[]            @relation("AdminAuditTarget")
  adventureCreationRequests AdventureCreationRequest[]
  advertisementEvents       AdvertisementEvent[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model City {
  id                   String          @id @default(cuid())
  name                 String
  /// Code INSEE à 5 chiffres, optionnel (saisie manuelle).
  inseeCode            String?         @unique
  postalCodes          String[]        @default([])
  latitude             Float?
  longitude            Float?
  population           Int?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  adventures           Adventure[]
  advertisementTargets Advertisement[] @relation("AdvertisementTargetCities")

  @@index([name])
}

model Adventure {
  id               String                 @id @default(cuid())
  name             String
  description      Json
  cityId           String
  city             City                   @relation(fields: [cityId], references: [id], onDelete: Restrict)
  latitude         Float
  longitude        Float
  distance         Float?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @default(now())
  /// Image de présentation (liste, fiche aventure).
  coverImageUrl    String?
  /// Même visuel pour le badge physique (trésor) et la bibliothèque app joueur.
  badgeImageUrl    String?
  enigmas          Enigma[]
  status           Boolean?               @default(true)
  creatorId        String
  creator          User                   @relation("CreatedAdventures", fields: [creatorId], references: [id])
  userAdventures   UserAdventures[]       @relation("AdventureUserAdventures")
  treasure         Treasure?
  adminAccesses    AdminAdventureAccess[]
  adventureReviews AdventureReview[]

  @@index([cityId])
}

enum AdvertiserKind {
  SHOP
  ASSOCIATION
  /// Commune / mairie.
  MAIRIE
  OTHER
}

enum AdvertisementEventType {
  IMPRESSION
  CLICK
}

enum AdventureReviewModerationStatus {
  /// Brouillon côté joueur (non soumis à la modération).
  DRAFT
  /// Soumis, en attente de traitement admin.
  PENDING
  /// Validé, affichable publiquement.
  APPROVED
  /// Refusé, non affiché.
  REJECTED
}

/// Publicité payante ou partenariale : commerces, associations, etc. — pas liée aux aventures.
/// Géo : une pub n’est pas forcément montrée partout ; côté appli on filtre selon la position / ville du joueur.
/// — `targetCities` vide : pas de filtre par villes du référentiel (comportement « large » ou autre règle produit).
/// — `targetCities` non vide : éligible seulement si le joueur est rattaché à l’une de ces villes (GPS, commune, etc.).
/// — `targetCenterLatitude` + `targetCenterLongitude` + `targetRadiusMeters` : zone circulaire optionnelle (mètres).
model Advertisement {
  id                    String               @id @default(cuid())
  /// Libellé interne pour l’admin.
  name                  String
  /// Type d’annonceur (commerce, association, mairie, autre).
  advertiserKind        AdvertiserKind
  /// Nom du partenaire tel qu’affiché (enseigne, asso, etc.).
  advertiserName        String
  title                 String?
  body                  String?
  imageUrl              String?
  targetUrl             String?
  /// Zone d’affichage dans l’appli (ex. : home, library).
  placement             String               @default("home")
  active                Boolean              @default(true)
  startsAt              DateTime?
  endsAt                DateTime?
  sortOrder             Int                  @default(0)
  targetCenterLatitude  Float?
  targetCenterLongitude Float?
  targetRadiusMeters    Int?
  targetCities          City[]               @relation("AdvertisementTargetCities")
  events                AdvertisementEvent[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([placement, active])
  @@index([startsAt, endsAt])
}

/// Événement analytique pub (impression affichée, clic). Agrégations par jour / utilisateur via requêtes sur `createdAt` et `userId`.
model AdvertisementEvent {
  id              String                 @id @default(cuid())
  advertisementId String
  advertisement   Advertisement          @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  type            AdvertisementEventType
  /// Joueur connecté ; null si visiteur anonyme.
  userId          String?
  user            User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime               @default(now())

  @@index([advertisementId, type, createdAt])
  @@index([advertisementId, createdAt])
  @@index([userId, createdAt])
}

model AdminAdventureAccess {
  id          String    @id @default(cuid())
  userId      String
  adventureId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  adventure   Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)

  @@unique([userId, adventureId])
  @@index([userId])
  @@index([adventureId])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  action       String
  actorUserId  String
  targetUserId String?
  payload      Json?
  createdAt    DateTime @default(now())
  actor        User     @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  target       User?    @relation("AdminAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
}

model AdventureCreationRequest {
  id          String   @id @default(cuid())
  message     String?
  status      String   @default("pending")
  requesterId String
  requester   User     @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([requesterId])
  @@index([status])
}

model Enigma {
  id             String    @id @default(cuid())
  name           String
  number         Int
  question       String
  uniqueResponse Boolean   @default(false)
  choice         Json?
  answer         String
  answerMessage  Json
  description    Json
  latitude       Float
  longitude      Float
  imageUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())
  adventureId    String
  adventure      Adventure @relation(fields: [adventureId], references: [id])

  @@unique([adventureId, number])
}

model Treasure {
  id          String    @id @default(cuid())
  name        String
  description Json
  latitude    Float
  code        String
  safeCode    String?   @default("AAA")
  longitude   Float
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())
  adventureId String    @unique
  adventure   Adventure @relation(fields: [adventureId], references: [id])
}

/// Progression joueur. Bibliothèque de badges : lignes avec `success === true` + `adventure.badgeImageUrl`.
model UserAdventures {
  id          String           @id @default(cuid())
  success     Boolean
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now())
  giftNumber  Int              @default(0)
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  adventureId String
  adventure   Adventure        @relation("AdventureUserAdventures", fields: [adventureId], references: [id])
  /// Avis / signalement associé à cette partie (écran de fin), si rempli.
  review      AdventureReview?

  @@index([userId, success])
}

/// Avis et signalements en fin de parcours (une entrée par joueur et par aventure).
/// Côté appli : proposer après succès (ou écran final) les cases « plus de badge », « trésor absent / volé » + texte optionnel.
/// Case à part : autorisation RGPD/explicit consent pour réutiliser avis / photo sur les réseaux ou supports de com’.
model AdventureReview {
  id                           String                          @id @default(cuid())
  /// Note de 1 à 5 (valider côté appli) ; null si pas d’étoiles (ex. signalement seul).
  rating                       Int?
  /// Commentaire libre (avis, détail du signalement) — peut être vide si seuls les booléens sont cochés.
  content                      String?
  image                        String?
  /// Workflow modération (brouillon → attente → validé / refusé).
  moderationStatus             AdventureReviewModerationStatus @default(PENDING)
  /// Le joueur autorise l’usage de ces contenus (texte, image, prénom ou pseudo affiché) pour communication publique (réseaux sociaux, site, newsletter, etc.).
  consentCommunicationNetworks Boolean                         @default(false)
  /// Plus de badge physique disponible (rupture, vol du point de retrait, etc.).
  reportsMissingBadge          Boolean                         @default(false)
  /// Trésor absent, vandalisé ou volé sur le lieu prévu.
  reportsStolenTreasure        Boolean                         @default(false)
  userId                       String
  user                         User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  adventureId                  String
  adventure                    Adventure                       @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  /// Partie terminée concernée (pour relier au bon passage) — optionnel.
  userAdventureId              String?                         @unique
  userAdventure                UserAdventures?                 @relation(fields: [userAdventureId], references: [id], onDelete: SetNull)
  createdAt                    DateTime                        @default(now())
  updatedAt                    DateTime                        @updatedAt

  @@unique([userId, adventureId])
  @@index([adventureId])
  @@index([userId])
  @@index([moderationStatus])
}
