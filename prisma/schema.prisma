// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id
  email          String           @unique
  name           String?
  address        String?
  postalCode     String?
  city           String?
  country        String?
  phone          String?
  emailVerified  Boolean          @default(false)
  image          String?
  role           String?          @default("user")
  banned         Boolean?         @default(false)
  banReason      String?
  banExpires     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  sessions       Session[]
  accounts       Account[]
  userAdventures UserAdventures[]
  adventures     Adventure[]      @relation("CreatedAdventures")
  clientNotices  ClientNotice[]
  adminAdventureAccesses AdminAdventureAccess[]
  adminAuditLogsAsActor AdminAuditLog[] @relation("AdminAuditActor")
  adminAuditLogsAsTarget AdminAuditLog[] @relation("AdminAuditTarget")
  adventureCreationRequests AdventureCreationRequest[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model City {
  id           String      @id @default(cuid())
  name         String
  /// Code INSEE à 5 chiffres, optionnel (saisie manuelle).
  inseeCode    String?     @unique
  postalCodes  String[]    @default([])
  latitude     Float?
  longitude    Float?
  population   Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  adventures   Adventure[]

  @@index([name])
}

model Adventure {
  id             String           @id @default(cuid())
  name           String
  description    Json
  cityId         String
  city           City             @relation(fields: [cityId], references: [id], onDelete: Restrict)
  latitude       Float
  longitude      Float
  distance       Float?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now())
  /// Image de présentation (liste, fiche aventure).
  coverImageUrl   String?
  /// Même visuel pour le badge physique (trésor) et la bibliothèque app joueur.
  badgeImageUrl   String?
  enigmas        Enigma[]
  status         Boolean?         @default(true)
  creatorId      String
  creator        User             @relation("CreatedAdventures", fields: [creatorId], references: [id])
  userAdventures UserAdventures[] @relation("AdventureUserAdventures")
  treasure       Treasure?
  adminAccesses  AdminAdventureAccess[]

  @@index([cityId])
}

model AdminAdventureAccess {
  id          String    @id @default(cuid())
  userId      String
  adventureId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  adventure   Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)

  @@unique([userId, adventureId])
  @@index([userId])
  @@index([adventureId])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  action       String
  actorUserId  String
  targetUserId String?
  payload      Json?
  createdAt    DateTime @default(now())
  actor        User     @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  target       User?    @relation("AdminAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
}

model AdventureCreationRequest {
  id          String   @id @default(cuid())
  message     String?
  status      String   @default("pending")
  requesterId String
  requester   User     @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([requesterId])
  @@index([status])
}

model Enigma {
  id             String    @id @default(cuid())
  name           String
  number         Int
  question       String
  uniqueResponse Boolean   @default(false)
  choice         Json?
  answer         String
  answerMessage  Json
  description    Json
  latitude       Float
  longitude      Float
  imageUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())
  adventureId    String
  adventure      Adventure @relation(fields: [adventureId], references: [id])

  @@unique([adventureId, number])
}

model Treasure {
  id          String    @id @default(cuid())
  name        String
  description Json
  latitude    Float
  code        String
  safeCode    String?   @default("AAA")
  longitude   Float
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())
  adventureId String    @unique
  adventure   Adventure @relation(fields: [adventureId], references: [id])
}

/// Progression joueur. Bibliothèque de badges : lignes avec `success === true` + `adventure.badgeImageUrl`.
model UserAdventures {
  id          String    @id @default(cuid())
  success     Boolean
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())
  userId      String
  giftNumber  Int       @default(0)
  user        User      @relation(fields: [userId], references: [id])
  adventureId String
  adventure   Adventure @relation("AdventureUserAdventures", fields: [adventureId], references: [id])

  @@index([userId, success])
}

model ClientNotice {
  id            String   @id @default(cuid())
  content       String
  adventureName String
  image         String?
  overdraft     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  userId        String
  user          User     @relation(fields: [userId], references: [id])
}
