// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String                     @id
  email                     String                     @unique
  name                      String?
  address                   String?
  postalCode                String?
  city                      String?
  country                   String?
  phone                     String?
  emailVerified             Boolean                    @default(false)
  image                     String?
  role                      String?                    @default("user")
  banned                    Boolean?                   @default(false)
  banReason                 String?
  banExpires                DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  sessions                  Session[]
  accounts                  Account[]
  userAdventures            UserAdventures[]
  /// Étapes d’énigme / trésor validées côté serveur (anti-triche avant fin d’aventure).
  adventureStepValidations  UserAdventureStepValidation[]
  adventures                Adventure[]                @relation("CreatedAdventures")
  /// Avis laissés sur les aventures.
  adventureReviews          AdventureReview[]
  adminAdventureAccesses    AdminAdventureAccess[]
  adminAuditLogsAsActor     AdminAuditLog[]            @relation("AdminAuditActor")
  adminAuditLogsAsTarget    AdminAuditLog[]            @relation("AdminAuditTarget")
  adminRequestsCreated      AdminRequest[]                 @relation("AdminRequestRequester")
  adminRequestsHandled      AdminRequest[]                 @relation("AdminRequestHandler")
  adminRequestTypesCreated  AdminRequestType[]             @relation("AdminRequestTypeCreator")
  advertisementEvents       AdvertisementEvent[]
  userBadges                UserBadge[]
  claimedAdventureBadgeInstances AdventureBadgeInstance[] @relation("BadgeClaimant")
  adventureBadgeStockEventsCreated AdventureBadgeStockEvent[]
  merchantAdvertisementAssignments MerchantAdvertisement[]
  partnerOfferClaimsAsPlayer      PartnerOfferClaim[]       @relation("PartnerOfferClaimPlayer")
  partnerOfferClaimsResolved      PartnerOfferClaim[]       @relation("PartnerOfferClaimResolver")
  advertisementDismissals         UserAdvertisementDismissal[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model City {
  id                   String          @id @default(cuid())
  name                 String
  /// Code INSEE à 5 chiffres, optionnel (saisie manuelle).
  inseeCode            String?         @unique
  postalCodes          String[]        @default([])
  latitude             Float?
  longitude            Float?
  population           Int?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  adventures           Adventure[]
  advertisementTargets Advertisement[] @relation("AdvertisementTargetCities")
  discoveryPoints      DiscoveryPoint[]

  @@index([name])
}

model Adventure {
  id               String                 @id @default(cuid())
  name             String
  description      Json
  cityId           String
  city             City                   @relation(fields: [cityId], references: [id], onDelete: Restrict)
  latitude         Float
  longitude        Float
  distance         Float?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @default(now())
  /// Image de présentation (liste, fiche aventure).
  coverImageUrl    String?
  /// Nombre d’exemplaires physiques numérotés (stock dans `AdventureBadgeInstance`). 0 = pas de suivi stock.
  physicalBadgeStockCount Int @default(0)
  enigmas          Enigma[]
  status           Boolean?               @default(true)
  creatorId        String
  creator          User                   @relation("CreatedAdventures", fields: [creatorId], references: [id])
  userAdventures   UserAdventures[]       @relation("AdventureUserAdventures")
  userAdventureStepValidations UserAdventureStepValidation[]
  treasure         Treasure?
  adminAccesses    AdminAdventureAccess[]
  adventureReviews AdventureReview[]
  /// Badge virtuel « complétion » (1 par aventure) — visuel dans `BadgeDefinition.imageUrl`.
  virtualBadge     BadgeDefinition?
  adventureBadgeInstances AdventureBadgeInstance[]
  badgeStockEvents AdventureBadgeStockEvent[]
  adminRequests       AdminRequest[]
  discoveryPoints     DiscoveryPoint[]

  @@index([cityId])
}

enum AdminRequestStatus {
  PENDING
  CLOSED
}

/// Type de demande admin configurable par les superadmin.
/// La `key` est un identifiant technique stable (slug unique) utilisé en code et dans les payloads.
model AdminRequestType {
  id              String         @id @default(cuid())
  /// Identifiant technique immuable (ex. "adventure_creation", "badge_restock").
  key             String         @unique
  /// Libellé métier affiché en interface.
  label           String
  /// Description courte d'aide à la saisie.
  description     String?
  /// Active/désactive la création de nouvelles demandes de ce type.
  isActive        Boolean        @default(true)
  /// Configuration libre (champs requis, hints UI, etc.).
  config          Json?
  createdByUserId String?
  createdBy       User?          @relation("AdminRequestTypeCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  requests        AdminRequest[]

  @@index([isActive])
}

/// Demande admin générique (création aventure, réassort badges, etc.).
model AdminRequest {
  id              String             @id @default(cuid())
  requestTypeId   String
  requestType     AdminRequestType   @relation(fields: [requestTypeId], references: [id], onDelete: Restrict)
  status          AdminRequestStatus @default(PENDING)
  requesterId     String
  requester       User               @relation("AdminRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  /// Aventure concernée si la demande est contextuelle (nullable pour demandes globales).
  adventureId     String?
  adventure       Adventure?         @relation(fields: [adventureId], references: [id], onDelete: SetNull)
  message         String?
  /// Données spécifiques au type (ex: quantityRequested pour badge_restock).
  payload         Json?
  closedAt        DateTime?
  closedByUserId  String?
  closedBy        User?              @relation("AdminRequestHandler", fields: [closedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([requestTypeId, status, createdAt])
  @@index([requesterId, status, createdAt])
  @@index([adventureId, status, createdAt])
  @@index([status, createdAt])
}

enum AdventureBadgeStockEventKind {
  /// Première mise en stock (création / config).
  INITIAL_SETUP
  /// Réapprovisionnement : ajout d’exemplaires disponibles.
  RESTOCK
  /// Incident : vol, rupture, trésor vide — perte du stock encore disponible.
  LOSS_INCIDENT
}

/// Journal opérationnel du stock physique (réassort, incidents) — motif dans `note`.
model AdventureBadgeStockEvent {
  id              String                      @id @default(cuid())
  adventureId     String
  adventure       Adventure                   @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  kind            AdventureBadgeStockEventKind
  /// Variation du nombre d’exemplaires **disponibles** (+ réappro, − perte).
  availableDelta  Int
  /// Nombre d’exemplaires encore disponibles après l’opération.
  availableAfter  Int
  /// Contexte : pourquoi (réassort, vol signalé, rupture, etc.).
  note            String
  createdByUserId String?
  createdBy       User?                       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime                    @default(now())

  @@index([adventureId, createdAt])
}

enum BadgeDefinitionKind {
  /// Badge débloqué en terminant une aventure avec succès.
  ADVENTURE_COMPLETE
  /// Nombre minimum d’aventures **distinctes** réussies.
  MILESTONE_ADVENTURES
  /// Kilomètres cumulés (parcours `Adventure.distance` des aventures réussies).
  MILESTONE_KM
  /// Badge obtenu via validation d’offre partenaire (publicité / commerce).
  PARTNER_OFFER
  /// Badge « point de découverte » géolocalisé (ville et/ou aventure).
  DISCOVERY
}

enum AdventureBadgeInstanceStatus {
  AVAILABLE
  CLAIMED
  MISSING
  STOLEN
}

/// Catalogue de badges (virtuel par aventure, paliers globaux, etc.).
model BadgeDefinition {
  id          String              @id @default(cuid())
  slug        String              @unique
  title       String
  imageUrl    String?
  kind        BadgeDefinitionKind
  /// Aventure liée (un seul badge virtuel par aventure).
  adventureId String?             @unique
  adventure   Adventure?          @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  /// Seuils pour les badges globaux, ex. `{ "minCompletedAdventures": 10 }`, `{ "minKmTotal": 50 }`.
  criteria    Json?
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  userBadges  UserBadge[]
  /// Une publicité partenaire peut référencer ce badge (au plus une pub par définition).
  partnerAdvertisement Advertisement?
  /// Point de découverte (1:1) — `kind` = DISCOVERY.
  discoveryPointId String?            @unique
  discoveryPoint   DiscoveryPoint?    @relation(fields: [discoveryPointId], references: [id], onDelete: Cascade)

  @@index([kind])
}

/// Lieu d’exploration hors fil d’énigmes : badge virtuel à collecter sur place (géofence).
/// `adventureId` null = ouvert à toute la ville ; renseigné = réservé aux joueurs ayant une partie sur cette aventure.
model DiscoveryPoint {
  id           String     @id @default(cuid())
  cityId       String
  city         City       @relation(fields: [cityId], references: [id], onDelete: Cascade)
  adventureId  String?
  adventure    Adventure? @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  title        String
  teaser       String?
  latitude     Float
  longitude    Float
  radiusMeters Int        @default(50)
  imageUrl     String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  badgeDefinition BadgeDefinition?

  @@index([cityId])
  @@index([adventureId])
}

/// Badge obtenu par un utilisateur (collection app).
model UserBadge {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeDefinitionId String
  badgeDefinition   BadgeDefinition @relation(fields: [badgeDefinitionId], references: [id], onDelete: Cascade)
  earnedAt          DateTime        @default(now())

  @@unique([userId, badgeDefinitionId])
  @@index([userId])
  @@index([badgeDefinitionId])
}

/// Exemplaire physique numéroté dans le trésor (stock).
model AdventureBadgeInstance {
  id              String   @id @default(cuid())
  adventureId     String
  adventure       Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  giftNumber      Int
  status          AdventureBadgeInstanceStatus @default(AVAILABLE)
  claimedByUserId String?
  claimedAt       DateTime?
  claimant        User?    @relation("BadgeClaimant", fields: [claimedByUserId], references: [id], onDelete: SetNull)

  @@unique([adventureId, giftNumber])
  @@index([adventureId, status])
  @@index([claimedByUserId])
}

enum AdvertiserKind {
  SHOP
  ASSOCIATION
  /// Commune / mairie.
  MAIRIE
  OTHER
}

enum AdvertisementEventType {
  IMPRESSION
  CLICK
}

enum PartnerOfferClaimStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

/// Utilisateur `role = merchant` autorisé à valider les demandes pour une publicité donnée.
model MerchantAdvertisement {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  advertisementId String
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([userId, advertisementId])
  @@index([advertisementId])
}

/// Demande joueur « j’ai profité de l’offre » — le commerçant approuve ou refuse.
model PartnerOfferClaim {
  id               String                  @id @default(cuid())
  userId           String
  user             User                    @relation("PartnerOfferClaimPlayer", fields: [userId], references: [id], onDelete: Cascade)
  advertisementId  String
  advertisement    Advertisement           @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  status           PartnerOfferClaimStatus @default(PENDING)
  rejectionReason  String?
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolvedBy       User?                   @relation("PartnerOfferClaimResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([advertisementId, status])
  @@index([userId, advertisementId])
  @@index([status, createdAt])
}

enum AdventureReviewModerationStatus {
  /// Brouillon côté joueur (non soumis à la modération).
  DRAFT
  /// Soumis, en attente de traitement admin.
  PENDING
  /// Validé, affichable publiquement.
  APPROVED
  /// Refusé, non affiché.
  REJECTED
}

/// Publicité payante ou partenariale : commerces, associations, etc. — pas liée aux aventures.
/// Géo : une pub n’est pas forcément montrée partout ; côté appli on filtre selon la position / ville du joueur.
/// — `targetCities` vide : pas de filtre par villes du référentiel (comportement « large » ou autre règle produit).
/// — `targetCities` non vide : éligible seulement si le joueur est rattaché à l’une de ces villes (GPS, commune, etc.).
/// — `targetCenterLatitude` + `targetCenterLongitude` + `targetRadiusMeters` : zone circulaire optionnelle (mètres).
model Advertisement {
  id                    String               @id @default(cuid())
  /// Libellé interne pour l’admin.
  name                  String
  /// Type d’annonceur (commerce, association, mairie, autre).
  advertiserKind        AdvertiserKind
  /// Nom du partenaire tel qu’affiché (enseigne, asso, etc.).
  advertiserName        String
  title                 String?
  body                  String?
  imageUrl              String?
  targetUrl             String?
  /// Zone d’affichage dans l’appli (ex. : home, library).
  placement             String               @default("home")
  active                Boolean              @default(true)
  startsAt              DateTime?
  endsAt                DateTime?
  sortOrder             Int                  @default(0)
  targetCenterLatitude  Float?
  targetCenterLongitude Float?
  targetRadiusMeters    Int?
  targetCities          City[]               @relation("AdvertisementTargetCities")
  events                AdvertisementEvent[]
  /// Badge débloqué une fois l’offre validée (type `PARTNER_OFFER`). Au plus une pub par badge.
  partnerBadgeDefinitionId String?           @unique
  partnerBadgeDefinition   BadgeDefinition?  @relation(fields: [partnerBadgeDefinitionId], references: [id], onDelete: SetNull)
  /// Nombre max de validations approuvées par joueur pour cette offre (avantage répétable) ; le badge reste unique.
  partnerMaxRedemptionsPerUser Int           @default(1)
  /// Si false : plus de nouvelles demandes ; les badges déjà obtenus restent en collection.
  partnerClaimsOpen     Boolean              @default(true)
  merchantAssignments   MerchantAdvertisement[]
  partnerOfferClaims    PartnerOfferClaim[]
  userDismissals        UserAdvertisementDismissal[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([placement, active])
  @@index([startsAt, endsAt])
}

/// Masquage persistant d’une publicité par joueur (liste `GET /api/advertisements` exclut ces ids si session présente).
model UserAdvertisementDismissal {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  advertisementId String
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([userId, advertisementId])
  @@index([userId])
  @@map("user_advertisement_dismissal")
}

/// Événement analytique pub (impression affichée, clic). Agrégations par jour / utilisateur via requêtes sur `createdAt` et `userId`.
model AdvertisementEvent {
  id              String                 @id @default(cuid())
  advertisementId String
  advertisement   Advertisement          @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  type            AdvertisementEventType
  /// Joueur connecté ; null si visiteur anonyme.
  userId          String?
  user            User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime               @default(now())

  @@index([advertisementId, type, createdAt])
  @@index([advertisementId, createdAt])
  @@index([userId, createdAt])
}

model AdminAdventureAccess {
  id          String    @id @default(cuid())
  userId      String
  adventureId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  adventure   Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)

  @@unique([userId, adventureId])
  @@index([userId])
  @@index([adventureId])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  action       String
  actorUserId  String
  targetUserId String?
  payload      Json?
  createdAt    DateTime @default(now())
  actor        User     @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  target       User?    @relation("AdminAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
}


model Enigma {
  id             String    @id @default(cuid())
  name           String
  number         Int
  question       String
  uniqueResponse Boolean   @default(false)
  choice         Json?
  answer         String
  answerMessage  Json
  description    Json
  latitude       Float
  longitude      Float
  imageUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())
  adventureId    String
  adventure      Adventure @relation(fields: [adventureId], references: [id])

  @@unique([adventureId, number])
}

model Treasure {
  id          String    @id @default(cuid())
  name        String
  description Json
  latitude    Float
  /// Combinaison / fin d’énigmes : ce que le joueur saisit pour **révéler le trésor sur la carte** (étape `treasure:map`).
  mapRevealCode     String
  /// Variante tolérée pour la même saisie (orthographe, etc.). Jamais exposé aux clients publics.
  mapRevealCodeAlt  String?
  /// Code **dans le trésor physique** (coffre, étiquette…), validé **après** la révélation sur la carte (étape `treasure`).
  chestCode         String
  chestCodeAlt      String?
  longitude   Float
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())
  adventureId String    @unique
  adventure   Adventure @relation(fields: [adventureId], references: [id])
}

/// Validation serveur d’une étape de parcours (`enigma:1`, …, `treasure:map`, `treasure`). Requis avant finalisation sur `POST /api/game/validate-treasure` (code coffre).
model UserAdventureStepValidation {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  adventureId  String
  adventure    Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  stepKey      String
  validatedAt  DateTime  @default(now())

  @@unique([userId, adventureId, stepKey])
  @@index([userId, adventureId])
}

/// Progression joueur. Badges virtuels : `UserBadge` lié au `BadgeDefinition` de l’aventure ; stock physique : `AdventureBadgeInstance`.
model UserAdventures {
  id          String           @id @default(cuid())
  success     Boolean
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now())
  giftNumber  Int              @default(0)
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  adventureId String
  adventure   Adventure        @relation("AdventureUserAdventures", fields: [adventureId], references: [id])
  /// Avis / signalement associé à cette partie (écran de fin), si rempli.
  review      AdventureReview?

  @@index([userId, success])
}

/// Avis et signalements en fin de parcours (une entrée par joueur et par aventure).
/// Côté appli : proposer après succès (ou écran final) les cases « plus de badge », « trésor absent / volé » + texte optionnel.
/// Case à part : autorisation RGPD/explicit consent pour réutiliser avis / photo sur les réseaux ou supports de com’.
model AdventureReview {
  id                           String                          @id @default(cuid())
  /// Note de 1 à 5 (valider côté appli) ; null si pas d’étoiles (ex. signalement seul).
  rating                       Int?
  /// Commentaire libre (avis, détail du signalement) — peut être vide si seuls les booléens sont cochés.
  content                      String?
  image                        String?
  /// Workflow modération (brouillon → attente → validé / refusé).
  moderationStatus             AdventureReviewModerationStatus @default(PENDING)
  /// Le joueur autorise l’usage de ces contenus (texte, image, prénom ou pseudo affiché) pour communication publique (réseaux sociaux, site, newsletter, etc.).
  consentCommunicationNetworks Boolean                         @default(false)
  /// Plus de badge physique disponible (rupture, vol du point de retrait, etc.).
  reportsMissingBadge          Boolean                         @default(false)
  /// Trésor absent, vandalisé ou volé sur le lieu prévu.
  reportsStolenTreasure        Boolean                         @default(false)
  userId                       String
  user                         User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  adventureId                  String
  adventure                    Adventure                       @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  /// Partie terminée concernée (pour relier au bon passage) — optionnel.
  userAdventureId              String?                         @unique
  userAdventure                UserAdventures?                 @relation(fields: [userAdventureId], references: [id], onDelete: SetNull)
  createdAt                    DateTime                        @default(now())
  updatedAt                    DateTime                        @updatedAt

  @@unique([userId, adventureId])
  @@index([adventureId])
  @@index([userId])
  @@index([moderationStatus])
}
