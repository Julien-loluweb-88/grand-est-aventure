// Référentiel ville (INSEE, cartes).

model City {
  id                   String          @id @default(cuid())
  name                 String
  /// Code INSEE à 5 chiffres, optionnel (saisie manuelle).
  inseeCode            String?         @unique
  postalCodes          String[]        @default([])
  latitude             Float?
  longitude            Float?
  population           Int?
  /// Règlement roue partenaires pour les lots « toute la ville » (repli si l’aventure n’a pas de texte dédié).
  partnerWheelTerms    String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  adventures           Adventure[]
  advertisementTargets Advertisement[] @relation("AdvertisementTargetCities")
  discoveryPoints      DiscoveryPoint[]
  adventurePartnerLots AdventurePartnerLot[]

  @@index([name])
}
