// Publicitûˋs, offres partenaires, ûˋvûˋnements analytiques.

enum AdvertiserKind {
  SHOP
  ASSOCIATION
  /// Commune / mairie.
  MAIRIE
  OTHER
}

enum AdvertisementEventType {
  IMPRESSION
  CLICK
}

enum PartnerOfferClaimStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

/// Workflow contenu commerûÏant sur un emplacement crûˋûˋ par le superadmin.
enum AdvertisementMerchantContentStatus {
  /// Emplacement crûˋûˋ, contenu non rempli.
  SLOT_EMPTY
  /// Brouillon commerûÏant (non soumis).
  DRAFT
  /// En attente de validation superadmin.
  PENDING_REVIEW
  /// Contenu validûˋ (ûˋligible û  lãaffichage si `active` + dates OK).
  APPROVED
  /// Refusûˋ par le superadmin ; le commerûÏant peut corriger.
  REJECTED
}

/// Utilisateur `role = merchant` autorisûˋ û  valider les demandes pour une publicitûˋ donnûˋe.
model MerchantAdvertisement {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  advertisementId String
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([userId, advertisementId])
  @@index([advertisementId])
}

/// Demande joueur ô¨ jãai profitûˋ de lãoffre ô£ ã le commerûÏant approuve ou refuse.
model PartnerOfferClaim {
  id               String                  @id @default(cuid())
  userId           String
  user             User                    @relation("PartnerOfferClaimPlayer", fields: [userId], references: [id], onDelete: Cascade)
  advertisementId  String
  advertisement    Advertisement           @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  status           PartnerOfferClaimStatus @default(PENDING)
  rejectionReason  String?
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolvedBy       User?                   @relation("PartnerOfferClaimResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  /// Gûˋnûˋration dãoffre au moment de la demande (promo pub) ã le plafond joueur est ûˋvaluûˋ par gûˋnûˋration.
  offerGeneration  Int                     @default(0)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([advertisementId, status])
  @@index([userId, advertisementId])
  @@index([userId, advertisementId, offerGeneration])
  @@index([status, createdAt])
}

/// Publicitûˋ payante ou partenariale : commerces, associations, etc. ã pas liûˋe aux aventures.
/// Gûˋo : une pub nãest pas forcûˋment montrûˋe partout ; cûÇtûˋ appli on filtre selon la position / ville du joueur.
/// ã `targetCities` vide : pas de filtre par villes du rûˋfûˋrentiel (comportement ô¨ large ô£ ou autre rû´gle produit).
/// ã `targetCities` non vide : ûˋligible seulement si le joueur est rattachûˋ û  lãune de ces villes (GPS, commune, etc.).
/// ã `targetCenterLatitude` + `targetCenterLongitude` + `targetRadiusMeters` : zone circulaire optionnelle (mû´tres).
model Advertisement {
  id                    String               @id @default(cuid())
  /// Libellûˋ interne pour lãadmin.
  name                  String
  /// Type dãannonceur (commerce, association, mairie, autre).
  advertiserKind        AdvertiserKind
  /// Nom du partenaire tel quãaffichûˋ (enseigne, asso, etc.).
  advertiserName        String
  title                 String?
  body                  String?
  imageUrl              String?
  targetUrl             String?
  /// Zone dãaffichage dans lãappli (ex. : home, library).
  placement             String               @default("home")
  active                Boolean              @default(true)
  startsAt              DateTime?
  endsAt                DateTime?
  sortOrder             Int                  @default(0)
  targetCenterLatitude  Float?
  targetCenterLongitude Float?
  targetRadiusMeters    Int?
  targetCities          City[]               @relation("AdvertisementTargetCities")
  events                AdvertisementEvent[]
  /// Badge dûˋbloquûˋ une fois lãoffre validûˋe (type `PARTNER_OFFER`). Au plus une pub par badge.
  partnerBadgeDefinitionId String?           @unique
  partnerBadgeDefinition   BadgeDefinition?  @relation(fields: [partnerBadgeDefinitionId], references: [id], onDelete: SetNull)
  /// Nombre max de validations approuvûˋes par joueur **pour la promo en cours** (badge unique) ; remise û  zûˋro quand le contenu pub change.
  partnerMaxRedemptionsPerUser Int           @default(1)
  /// Si false : plus de nouvelles demandes ; les badges dûˋjû  obtenus restent en collection.
  partnerClaimsOpen     Boolean              @default(true)
  /// Incrûˋmentûˋ quand le contenu pub (titre, texte, image) est validûˋ avec changement ã nouveau cycle de validations joueur.
  partnerOfferGeneration Int                 @default(0)
  /// CommerûÏant propriûˋtaire de lãemplacement (au plus un par pub).
  ownerMerchantUserId   String?
  ownerMerchant         User?                @relation("AdvertisementOwnerMerchant", fields: [ownerMerchantUserId], references: [id], onDelete: SetNull)
  merchantContentStatus AdvertisementMerchantContentStatus @default(APPROVED)
  merchantRejectionReason String?
  /// Brouillon commerûÏant en attente de validation (rûˋ-modûˋration : la version live reste affichûˋe).
  pendingTitle          String?
  pendingBody           String?
  pendingImageUrl       String?
  pendingTargetUrl      String?
  pendingPartnerBadgeTitle String?
  pendingPartnerBadgeImageUrl String?
  pendingPartnerMaxRedemptionsPerUser Int?
  pendingPartnerClaimsOpen Boolean?
  merchantAssignments   MerchantAdvertisement[]
  partnerOfferClaims    PartnerOfferClaim[]
  userDismissals        UserAdvertisementDismissal[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([placement, active])
  @@index([startsAt, endsAt])
  @@index([ownerMerchantUserId])
  @@index([merchantContentStatus])
}

/// Masquage persistant dãune publicitûˋ par joueur (liste `GET /api/advertisements` exclut ces ids si session prûˋsente).
model UserAdvertisementDismissal {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  advertisementId String
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([userId, advertisementId])
  @@index([userId])
  @@map("user_advertisement_dismissal")
}

/// ûvûˋnement analytique pub (impression affichûˋe, clic). Agrûˋgations par jour / utilisateur via requûˆtes sur `createdAt` et `userId`.
model AdvertisementEvent {
  id              String                 @id @default(cuid())
  advertisementId String
  advertisement   Advertisement          @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  type            AdvertisementEventType
  /// Joueur connectûˋ ; null si visiteur anonyme.
  userId          String?
  user            User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime               @default(now())

  @@index([advertisementId, type, createdAt])
  @@index([advertisementId, createdAt])
  @@index([userId, createdAt])
}
